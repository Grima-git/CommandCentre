# ─────────────────────────────────────────────────────────────────────────────
# Command Centre — Environment Variables
# Copy this file to .env.local for local development.
# In production (Netlify) set each variable in Site → Environment Variables.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────

# Full connection string — find in Supabase → Project Settings → Database → URI
# Use the "Transaction" pooler URL (port 5432) for Netlify serverless functions.
# Format: postgresql://<user>:<password>@<host>:5432/postgres?sslmode=require
DATABASE_URL=

# ── Auth ─────────────────────────────────────────────────────────────────────

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Set to "1" for local dev only to bypass Microsoft login.
# netlify.toml forces this to "0" in production automatically.
DEV_AUTH_BYPASS=0

# Microsoft Entra ID (Azure AD) — required for production SSO.
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations.
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# Optional comma-separated email domains allowed through the MyFirst Microsoft button.
AUTH_MICROSOFT_ENTRA_ALLOWED_DOMAINS=

# ARMA Microsoft Entra ID (separate company SSO).
# Redirect URI: https://command-centre-myfirst.netlify.app/api/auth/callback/arma-microsoft-entra-id
AUTH_ARMA_ENTRA_ID=
AUTH_ARMA_ENTRA_SECRET=
AUTH_ARMA_ENTRA_ISSUER=https://login.microsoftonline.com/<arma-tenant-id>/v2.0
# Optional but recommended. Comma-separated email domains allowed through the ARMA Microsoft button.
AUTH_ARMA_ALLOWED_DOMAINS=

# ── Anthropic / OD1N ─────────────────────────────────────────────────────────

# Anthropic API key — https://console.anthropic.com/account/keys
YDI_ANTHROPIC_KEY=

# ── OpenGI SOAP ──────────────────────────────────────────────────────────────

# SOAP calls are proxied through the whitelisted Windows Server VM so that
# Netlify serverless functions (no fixed IP) can reach OpenGI.
# SOAP_PROXY_URL  — http://<server-ip>:3001
# SOAP_PROXY_SECRET — shared secret configured in soap-proxy/server.js
SOAP_PROXY_URL=
SOAP_PROXY_SECRET=

# ── PBX (FusionPBX) ──────────────────────────────────────────────────────────

PBX_API_BASE_URL=
PBX_DOMAIN_UUID=
PBX_API_KEY=

# ── SMS (FireText) ───────────────────────────────────────────────────────────

FIRETEXT_API_KEY=
# Optional — defaults to "YoungDriver" if unset
FIRETEXT_SENDER_ID=YoungDriver

# ── Sage HR ──────────────────────────────────────────────────────────────────

SAGE_HR_BASE_URL=
SAGE_HR_API_KEY=

# ── Piper TTS (OD1N voice) ───────────────────────────────────────────────────
# Optional. If unset, OD1N runs text-only (no voice).
# Point to a self-hosted Piper HTTP service (e.g. a VPS running piper-http).
# Must be an https:// URL in production.
PIPER_TTS_URL=
# Optional overrides:
# PIPER_TTS_VOICE=en_GB-northern_english_male-medium
# PIPER_TTS_LENGTH_SCALE=1.02
# PIPER_TTS_NOISE_SCALE=0.68
# PIPER_TTS_NOISE_W_SCALE=0.82
