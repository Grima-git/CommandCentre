# Auth.js / NextAuth v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Microsoft Entra ID (Azure AD) — fill these once you register the app in entra.microsoft.com
# App registration > Overview gives you the Client ID and Tenant ID.
# App registration > Certificates & secrets > New client secret gives you the secret.
# App registration > Authentication > add redirect URI: http://localhost:3000/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<your-tenant-id>/v2.0

# When 1, skip Entra ID and log in as a mock user. Use for local dev until Entra is wired up.
DEV_AUTH_BYPASS=1

# ----------------------------------------------------------------------
# Connectors — fill in as you provide each one. While unset, the data
# orchestrator falls back to mock data so the dashboard still renders.
# ----------------------------------------------------------------------

# Renewals platform (Salesforce / Guidewire / custom REST — implementation
# in lib/data/connectors/renewals-api.ts).
RENEWALS_API_BASE_URL=
RENEWALS_API_KEY=

# OpenGI InfoService SOAP endpoint (usp_Report_Renewals_Tracker)
OPENGI_SOAP_URL=https://infoservice-myfi001.opengihosting.com:10261/InfoService/InfoService

# Anthropic — used for the AI Insights panel once data is flowing.
ANTHROPIC_API_KEY=

# FireText SMS
FIRETEXT_API_KEY=
FIRETEXT_SENDER_ID=OD1N

# Sage HR
SAGE_HR_BASE_URL=https://yourcompany.sage.hr/api
SAGE_HR_API_KEY=
